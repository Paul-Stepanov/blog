# ============================================
# Application
# ============================================
APP_NAME=Blog
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# ============================================
# Localization
# ============================================
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

# ============================================
# Maintenance
# ============================================
APP_MAINTENANCE_DRIVER=file

# ============================================
# Logging
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# Database - PostgreSQL
# ============================================
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=blog
DB_USERNAME=blog_user
DB_PASSWORD=secret

# ============================================
# Session & Cache
# ============================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=blog_

# ============================================
# Redis
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=dev_redis_secret
REDIS_PORT=6379

# ============================================
# Queue
# ============================================
QUEUE_CONNECTION=redis

# ============================================
# Broadcast
# ============================================
BROADCAST_CONNECTION=redis

# ============================================
# Mail (Mailpit)
# ============================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@blog.local"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# Filesystem
# ============================================
FILESYSTEM_DISK=local

# ============================================
# AWS (optional)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# Frontend (Vite)
# ============================================
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"