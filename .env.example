# Docker Compose Environment Variables
# Copy this file to .env and configure your settings

# ============================================
# Application
# ============================================
APP_NAME=Blog
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ============================================
# Database - PostgreSQL
# ============================================
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=blog
DB_USERNAME=blog_user
DB_PASSWORD=secret

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ============================================
# Mail (Mailpit for development)
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@blog.local"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# Frontend (Vue.js)
# ============================================
VITE_API_URL=http://localhost/api
VITE_APP_URL=http://localhost

# ============================================
# Docker Ports (change if conflicts)
# ============================================
NGINX_PORT=80
NGINX_SSL_PORT=443
POSTGRES_PORT=5432
REDIS_PORT=6379
VITE_PORT=5173
ADMINER_PORT=8080
MAILPIT_PORT=8025
MAILPIT_SMTP_PORT=1025

# ============================================
# Development Settings
# ============================================
PHP_IDE_CONFIG=serverName=blog
XDEBUG_MODE=debug,coverage
XDEBUG_CONFIG=client_host=host.docker.internal client_port=9003